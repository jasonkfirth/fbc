#!/usr/bin/make -f
# ======================================================================
# debian/rules
# ======================================================================

export DH_VERBOSE=1
export DEB_BUILD_MAINT_OPTIONS=hardening=+all optimize=-lto
DEB_BUILD_PROFILES ?=

DEB_HOST_ARCH := $(shell dpkg-architecture -qDEB_HOST_ARCH)
BUILD_JS := yes
ifneq ($(filter nojs,$(DEB_BUILD_PROFILES)),)
BUILD_JS := no
endif
BUILD_ANDROID := no
ifneq ($(filter android,$(DEB_BUILD_PROFILES)),)
BUILD_ANDROID := yes
endif

# ------------------------------------------------------------
# Parallelism
# ------------------------------------------------------------

JOBS ?= $(shell nproc)
PARMAKE := $(MAKE) -j$(JOBS)

# ------------------------------------------------------------
# Debian architecture → GNU triplet mapping
# ------------------------------------------------------------

MULTILIB :=
TARGET_TRIPLET :=
BOOTSTRAP_DIR_KEY :=
FBC_TARGET_KEY :=
ARM_CPU_MAKE_ARGS :=

ifeq ($(DEB_HOST_ARCH),amd64)
TARGET_TRIPLET := x86_64-linux-gnu
BOOTSTRAP_DIR_KEY := linux-amd64
FBC_TARGET_KEY := linux-x86_64
endif

ifeq ($(DEB_HOST_ARCH),i386)
TARGET_TRIPLET := i686-linux-gnu
MULTILIB := 32
BOOTSTRAP_DIR_KEY := linux-i386
FBC_TARGET_KEY := linux-x86
endif

ifeq ($(DEB_HOST_ARCH),arm64)
TARGET_TRIPLET := aarch64-linux-gnu
BOOTSTRAP_DIR_KEY := linux-arm64
FBC_TARGET_KEY := linux-aarch64
endif

ifeq ($(DEB_HOST_ARCH),armhf)
TARGET_TRIPLET := arm-linux-gnueabihf
BOOTSTRAP_DIR_KEY := linux-armhf
FBC_TARGET_KEY := linux-arm
endif

ifeq ($(DEB_HOST_ARCH),armhf)
ifeq ($(FBC_PACKAGE_ARM_ARCH),armv6+fp)
ARM_CPU_MAKE_ARGS := ARM_VER=v6 ARM_FLOAT_ABI=hf DEFAULT_CPUTYPE_ARM=FB_CPUTYPE_ARMV6_FP
endif
endif

ifeq ($(DEB_HOST_ARCH),armel)
TARGET_TRIPLET := arm-linux-gnueabi
BOOTSTRAP_DIR_KEY := linux-armel
FBC_TARGET_KEY := linux-arm
endif

ifeq ($(DEB_HOST_ARCH),ppc64el)
TARGET_TRIPLET := powerpc64le-linux-gnu
BOOTSTRAP_DIR_KEY := linux-ppc64el
FBC_TARGET_KEY := linux-powerpc64le
endif

ifeq ($(DEB_HOST_ARCH),s390x)
TARGET_TRIPLET := s390x-linux-gnu
BOOTSTRAP_DIR_KEY := linux-s390x
FBC_TARGET_KEY := linux-s390x
endif

ifeq ($(DEB_HOST_ARCH),riscv64)
TARGET_TRIPLET := riscv64-linux-gnu
BOOTSTRAP_DIR_KEY := linux-riscv64
FBC_TARGET_KEY := linux-riscv64
endif

ifeq ($(DEB_HOST_ARCH),loong64)
TARGET_TRIPLET := loongarch64-linux-gnu
BOOTSTRAP_DIR_KEY := linux-loongarch64
FBC_TARGET_KEY := linux-loongarch64
endif

ifeq ($(TARGET_TRIPLET),)
$(error Unsupported DEB_HOST_ARCH $(DEB_HOST_ARCH))
endif

export TARGET=$(TARGET_TRIPLET)
export TARGET_TRIPLET
export FBC_TARGET=$(TARGET_TRIPLET)
export MULTILIB
export FBTARGET_DIR_OVERRIDE=$(BOOTSTRAP_DIR_KEY)

# ------------------------------------------------------------
# Bootstrap compiler
# ------------------------------------------------------------

FBC_BOOTSTRAP := $(CURDIR)/bin/fbc -i $(CURDIR)/inc

# ------------------------------------------------------------
# Android target toolchain
# ------------------------------------------------------------

ANDROID_API ?= 26
ANDROID_TARGET_TRIPLET ?= aarch64-linux-android
ANDROID_FBTARGET_KEY ?= android-aarch64
ANDROID_NDK_HOME ?= $(firstword $(wildcard /usr/lib/android-sdk/ndk/* /usr/lib/android-sdk/ndk-bundle /usr/lib/android-ndk* /opt/android-ndk*))
ANDROID_TOOLCHAIN_PREBUILT ?= $(firstword $(wildcard $(ANDROID_NDK_HOME)/toolchains/llvm/prebuilt/linux-x86_64 $(ANDROID_NDK_HOME)/toolchains/llvm/prebuilt/*))
ANDROID_TOOLCHAIN_BINDIR := $(ANDROID_TOOLCHAIN_PREBUILT)/bin
ANDROID_CC := $(ANDROID_TOOLCHAIN_BINDIR)/$(ANDROID_TARGET_TRIPLET)$(ANDROID_API)-clang
ANDROID_CXX := $(ANDROID_TOOLCHAIN_BINDIR)/$(ANDROID_TARGET_TRIPLET)$(ANDROID_API)-clang++
ANDROID_AR := $(ANDROID_TOOLCHAIN_BINDIR)/llvm-ar
ANDROID_RANLIB := $(ANDROID_TOOLCHAIN_BINDIR)/llvm-ranlib

# ------------------------------------------------------------
# Debian hardening flags
# ------------------------------------------------------------

DPKG_CFLAGS_RAW   := $(shell dpkg-buildflags --get CFLAGS)
DPKG_CPPFLAGS     := $(shell dpkg-buildflags --get CPPFLAGS)
DPKG_LDFLAGS_RAW  := $(shell dpkg-buildflags --get LDFLAGS)

# The FreeBASIC bootstrap/compiler build does not currently survive Debian's
# LTO flags reliably. Keep hardening, but drop -flto/-ffat-lto-objects here.
DPKG_CFLAGS  := $(filter-out -flto=% -ffat-lto-objects,$(DPKG_CFLAGS_RAW))
DPKG_LDFLAGS := $(filter-out -flto=% -ffat-lto-objects,$(DPKG_LDFLAGS_RAW))

# Force recursive make invocations to use the same sanitized Debian flags.
export CPPFLAGS := $(DPKG_CPPFLAGS)
export CFLAGS   := $(DPKG_CFLAGS)
export CXXFLAGS := $(DPKG_CFLAGS)
export LDFLAGS  := $(DPKG_LDFLAGS)

# ------------------------------------------------------------
# Default rule
# ------------------------------------------------------------

%:
	dh $@

# ------------------------------------------------------------
# Clean
# ------------------------------------------------------------

override_dh_auto_clean:

	rm -rf bin obj
	rm -rf src/compiler/obj
	rm -rf src/rtlib/obj
	rm -rf src/fbrt/obj
	rm -rf src/gfxlib2/obj
	rm -rf lib/freebasic

	rm -rf debian/tmp
	rm -rf debian/.debhelper

	rm -f debian/*.substvars
	rm -f debian/files
	rm -f debian/*.log
	rm -f debian/debhelper-build-stamp

	mkdir -p debian/source
	echo "3.0 (quilt)" > debian/source/format

# ------------------------------------------------------------
# Build
# ------------------------------------------------------------

override_dh_auto_build:

	rm -f contrib/swig/swig.exe

	$(MAKE) TARGET_TRIPLET="$(TARGET_TRIPLET)" TARGET="$(TARGET)" MULTILIB="$(MULTILIB)" \
		$(ARM_CPU_MAKE_ARGS) \
		CPPFLAGS="$(CPPFLAGS)" \
		CFLAGS="$(CFLAGS)" \
		CXXFLAGS="$(CXXFLAGS)" \
		LDFLAGS="$(LDFLAGS)" \
		bootstrap-minimal

	@test -x bin/fbc || { echo "ERROR: bootstrap compiler missing"; exit 1; }

	$(PARMAKE) TARGET_TRIPLET="$(TARGET_TRIPLET)" TARGET="$(TARGET)" MULTILIB="$(MULTILIB)" \
		$(ARM_CPU_MAKE_ARGS) \
		rtlib fbrt gfxlib2 sfxlib \
		FBC="$(FBC_BOOTSTRAP)" \
		BUILD_FBC_TARGET="$(FBC_TARGET_KEY)" \
		CPPFLAGS="$(CPPFLAGS)" \
		CFLAGS="$(CFLAGS)" \
		CXXFLAGS="$(CXXFLAGS)" \
		LDFLAGS="$(LDFLAGS)"

	$(PARMAKE) TARGET_TRIPLET="$(TARGET_TRIPLET)" TARGET="$(TARGET)" MULTILIB="$(MULTILIB)" \
		$(ARM_CPU_MAKE_ARGS) \
		compiler \
		FBC="$(FBC_BOOTSTRAP)" \
		BUILD_FBC_TARGET="$(FBC_TARGET_KEY)" \
		CPPFLAGS="$(CPPFLAGS)" \
		CFLAGS="$(CFLAGS)" \
		CXXFLAGS="$(CXXFLAGS)" \
		LDFLAGS="$(LDFLAGS)"

ifeq ($(BUILD_JS),yes)
	$(PARMAKE) TARGET_TRIPLET="$(TARGET_TRIPLET)" TARGET="$(TARGET)" MULTILIB="$(MULTILIB)" \
		$(ARM_CPU_MAKE_ARGS) \
		compiler-js \
		FBC="$(FBC_BOOTSTRAP)" \
		BUILD_FBC_TARGET="$(FBC_TARGET_KEY)" \
		CPPFLAGS="$(CPPFLAGS)" \
		CFLAGS="$(CFLAGS)" \
		CXXFLAGS="$(CXXFLAGS)" \
		LDFLAGS="$(LDFLAGS)"

	$(PARMAKE) TARGET_TRIPLET="asmjs-unknown-emscripten" TARGET="asmjs-unknown-emscripten" \
		rtlib fbrt gfxlib2 sfxlib \
		FBC="$(FBC_BOOTSTRAP)" \
		FBTARGET_DIR_OVERRIDE="js-asmjs" \
		CPPFLAGS= \
		CFLAGS= \
		CXXFLAGS= \
		LDFLAGS=
endif

ifeq ($(BUILD_ANDROID),yes)
	@test -n "$(ANDROID_NDK_HOME)" || { echo "ERROR: Android NDK not found. Install google-android-ndk-r28-installer or set ANDROID_NDK_HOME."; exit 1; }
	@test -x "$(ANDROID_CC)" || { echo "ERROR: Android clang not found: $(ANDROID_CC)"; exit 1; }
	@test -x "$(ANDROID_AR)" || { echo "ERROR: Android llvm-ar not found: $(ANDROID_AR)"; exit 1; }
	@test -x "$(ANDROID_RANLIB)" || { echo "ERROR: Android llvm-ranlib not found: $(ANDROID_RANLIB)"; exit 1; }

	$(PARMAKE) TARGET_TRIPLET="$(TARGET_TRIPLET)" TARGET="$(TARGET)" MULTILIB="$(MULTILIB)" \
		$(ARM_CPU_MAKE_ARGS) \
		compiler-android \
		FBC="$(FBC_BOOTSTRAP)" \
		BUILD_FBC_TARGET="$(FBC_TARGET_KEY)" \
		CPPFLAGS="$(CPPFLAGS)" \
		CFLAGS="$(CFLAGS)" \
		CXXFLAGS="$(CXXFLAGS)" \
		LDFLAGS="$(LDFLAGS)"

	$(PARMAKE) TARGET_TRIPLET="$(ANDROID_TARGET_TRIPLET)" TARGET="$(ANDROID_TARGET_TRIPLET)" MULTILIB="" \
		FBTARGET_DIR_OVERRIDE="$(ANDROID_FBTARGET_KEY)" \
		BUILD_PREFIX= \
		CC="$(ANDROID_CC)" \
		CXX="$(ANDROID_CXX)" \
		CLANG="$(ANDROID_CC)" \
		AS="$(ANDROID_CC)" \
		LD="$(ANDROID_CC)" \
		AR="$(ANDROID_AR)" \
		RANLIB="$(ANDROID_RANLIB)" \
		rtlib fbrt gfxlib2 sfxlib \
		FBC="$(FBC_BOOTSTRAP)" \
		BUILD_FBC_TARGET="$(ANDROID_FBTARGET_KEY)" \
		BUILD_FBC_BUILDPREFIX= \
		CPPFLAGS= \
		CFLAGS= \
		CXXFLAGS= \
		LDFLAGS=
endif

# ------------------------------------------------------------
# Install
# ------------------------------------------------------------

override_dh_auto_install:

	$(PARMAKE) TARGET_TRIPLET="$(TARGET_TRIPLET)" TARGET="$(TARGET)" MULTILIB="$(MULTILIB)" install \
		$(ARM_CPU_MAKE_ARGS) \
		DESTDIR=$(CURDIR)/debian/tmp \
		prefix=/usr \
		FBC="$(FBC_BOOTSTRAP)" \
		BUILD_FBC_TARGET="$(FBC_TARGET_KEY)"

ifeq ($(BUILD_JS),yes)
	$(PARMAKE) TARGET_TRIPLET="$(TARGET_TRIPLET)" TARGET="$(TARGET)" MULTILIB="$(MULTILIB)" install-js \
		$(ARM_CPU_MAKE_ARGS) \
		DESTDIR=$(CURDIR)/debian/tmp \
		prefix=/usr \
		FBC="$(FBC_BOOTSTRAP)" \
		BUILD_FBC_TARGET="$(FBC_TARGET_KEY)"
endif

ifeq ($(BUILD_ANDROID),yes)
	$(PARMAKE) TARGET_TRIPLET="$(TARGET_TRIPLET)" TARGET="$(TARGET)" MULTILIB="$(MULTILIB)" install-android \
		$(ARM_CPU_MAKE_ARGS) \
		DESTDIR=$(CURDIR)/debian/tmp \
		prefix=/usr \
		FBC="$(FBC_BOOTSTRAP)" \
		BUILD_FBC_TARGET="$(FBC_TARGET_KEY)" \
		ANDROID_BUILD_LIBDIR="$(CURDIR)/lib/freebasic/$(ANDROID_FBTARGET_KEY)"
endif

	if [ -d debian/tmp/usr/lib/freebasic ]; then \
		cd debian/tmp/usr/lib/freebasic; \
		case "$(DEB_HOST_ARCH)" in \
			amd64)   ln -sfn linux-amd64 linux-x86_64 ;; \
			i386)    ln -sfn linux-i386 linux-x86 ;; \
			arm64)   ln -sfn linux-arm64 linux-aarch64 ;; \
			armhf)   ln -sfn linux-armhf linux-arm ;; \
			ppc64el) ln -sfn linux-ppc64el linux-powerpc64le ;; \
		esac; \
	fi

# ------------------------------------------------------------
# Cleanup packaging artifacts
# ------------------------------------------------------------

	find debian/tmp -name ".git*" -delete || true
	find debian/tmp -name ".svn" -type d -exec rm -rf {} + || true
	find debian/tmp -name ".hg" -type d -exec rm -rf {} + || true

	rm -rf debian/tmp/usr/share/doc/freebasic/manual/cache* || true
	rm -f debian/tmp/usr/share/freebasic/contrib/swig/swig.exe || true
	mkdir -p debian/tmp/usr/share/freebasic
	cp -a examples debian/tmp/usr/share/freebasic/
	find debian/tmp/usr/share/freebasic/examples -type f \
		\( -name '*.o' -o -name '*.obj' -o -name '*.exe' -o -name '*.dll' -o -name '*.so' \) \
		-delete
	rm -f debian/tmp/usr/share/freebasic/examples/sfxlib/showcase
	find debian/tmp/usr/share/freebasic/examples -type f -perm /111 \
		! -name '*.sh' ! -name '*.ps1' ! -name '*.bat' ! -name '*.cmd' \
		-delete
	find debian/tmp/usr/share/freebasic/examples -type f \
		\( -path '*/data/*' -name '*.txt' -o -path '*/data/*' -name 'License' \
		   -o -path '*/obj/*' -name 'deleteme.txt' \
		   -o -path '*/COM/*' -name '*.html' \) \
		-delete || true
	if [ -f debian/tmp/usr/share/freebasic/examples/graphics/SDL/data/Vera.ttf ]; then \
		rm -f debian/tmp/usr/share/freebasic/examples/graphics/SDL/data/Vera.ttf; \
		ln -s ../../../../../fonts/truetype/ttf-bitstream-vera/Vera.ttf \
			debian/tmp/usr/share/freebasic/examples/graphics/SDL/data/Vera.ttf; \
	fi
	find debian/tmp/usr/share/freebasic/examples -type d -empty -delete || true

# ------------------------------------------------------------
# FLTK license relocation
# ------------------------------------------------------------

	for incroot in freebasic freebasic-js freebasic-android; do \
		if [ -f "debian/tmp/usr/include/$$incroot/FLTK/LICENSE" ]; then \
			docpkg=freebasic-bindings; \
			case "$$incroot" in \
				freebasic-js) docpkg=freebasic-js ;; \
				freebasic-android) docpkg=freebasic-android ;; \
			esac; \
			mkdir -p "debian/tmp/usr/share/doc/$$docpkg"; \
			mv "debian/tmp/usr/include/$$incroot/FLTK/LICENSE" \
			   "debian/tmp/usr/share/doc/$$docpkg/FLTK-LICENSE"; \
			ln -sf "../../../share/doc/$$docpkg/FLTK-LICENSE" \
			   "debian/tmp/usr/include/$$incroot/FLTK/LICENSE"; \
		fi; \
	done

# ------------------------------------------------------------
# Remove duplicate GPL texts
# ------------------------------------------------------------

	rm -f debian/tmp/usr/share/doc/freebasic/*/gpl.txt.gz || true

# ------------------------------------------------------------
# Tests
# ------------------------------------------------------------

override_dh_auto_test:
	true

execute_after_dh_installdocs:
	find debian/freebasic-doc/usr/share/doc/freebasic -name ".git*" -delete || true
	rm -rf debian/freebasic-doc/usr/share/doc/freebasic/manual/cache* || true
	find debian/freebasic-doc/usr/share/doc/freebasic \
		\( -name gpl.txt -o -name lgpl.txt \) -delete || true
	if cmp -s debian/freebasic-doc/usr/share/doc/freebasic/manual/html/images/putgfx2.png \
	         debian/freebasic-doc/usr/share/doc/freebasic/manual/html/images/sample.png; then \
		rm -f debian/freebasic-doc/usr/share/doc/freebasic/manual/html/images/sample.png; \
		ln -s putgfx2.png debian/freebasic-doc/usr/share/doc/freebasic/manual/html/images/sample.png; \
	fi
	if cmp -s debian/freebasic-doc/usr/share/doc/freebasic/manual/templates/default/code/fbhelp_doctoc.tpl.txt \
	         debian/freebasic-doc/usr/share/doc/freebasic/manual/templates/default/code/texinfo_doctoc.tpl.texinfo; then \
		rm -f debian/freebasic-doc/usr/share/doc/freebasic/manual/templates/default/code/texinfo_doctoc.tpl.texinfo; \
		ln -s fbhelp_doctoc.tpl.txt debian/freebasic-doc/usr/share/doc/freebasic/manual/templates/default/code/texinfo_doctoc.tpl.texinfo; \
	fi
	find debian/freebasic-doc/usr/share/doc/freebasic -type d -empty -delete || true


# ======================================================================
# End of debian/rules
# ======================================================================
